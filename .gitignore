# Environment variables — never commit secrets
.env
.env.local

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# Data — raw Excel files and embedding model weights are large, keep off git
data/raw/
data/models/

# Local prompt drafts — kept out of git
prompts/

# Reference projects dropped in for learning — not part of this codebase
temp/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Database files (if running SQLite locally)
*.db
*.sqlite3

# Docker
.docker/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Alembic — don't ignore versions/, only the compiled cache
migrations/__pycache__/

# Playwright CLI scratch output (snapshots, screenshots, console logs)
.playwright-cli/
tests/e2e/*.png
backend/*.png
backend/*.yml
