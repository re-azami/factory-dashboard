# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: deepseek | anthropic | openai | ollama
LLM_PROVIDER=deepseek

# DeepSeek (default provider — used when LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_SIMPLE=deepseek-v4-flash
DEEPSEEK_MODEL_DEEP=deepseek-v4-pro

# Anthropic (used when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_SIMPLE=claude-sonnet-4-6
ANTHROPIC_MODEL_DEEP=claude-opus-4-7

# OpenAI (used when LLM_PROVIDER=openai — fill in models when ready)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_SIMPLE=
# OPENAI_MODEL_DEEP=

# Ollama (uses LLM_MODEL — local runtimes load one model at a time)
# Ollama runs on your machine; Docker reaches it via host.docker.internal
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# OLLAMA_API_KEY=ollama   ← Ollama doesn't need a real key but the field is required
# LLM_MODEL=

# Deep-mode reasoning knobs — maximum thinking/effort in data-science mode
DEEP_THINKING_BUDGET_TOKENS=16000   # Claude extended-thinking token budget
DEEP_REASONING_EFFORT=high          # DeepSeek / OpenAI-compat reasoning effort

# ── Database ──────────────────────────────────────────────────────────────────
# These are set automatically by docker-compose. Only override if running locally.
# DATABASE_URL=postgresql+psycopg://factory:factory@localhost:5432/factory
# DATABASE_URL_RO=postgresql+psycopg://factory_ro:factory_ro@localhost:5432/factory

# ── Embeddings ────────────────────────────────────────────────────────────────
# Set automatically by docker-compose. Only override if running locally.
# EMBEDDINGS_URL=http://localhost:8001

# ── Admin seed ────────────────────────────────────────────────────────────────
# On first startup (only when the `users` table is empty), the backend seeds an
# admin user from these vars and grants it every permission. If either is
# missing the seed is skipped — you must then create the admin manually.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-on-first-login

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# JWT_SECRET MUST be set in real environments (empty placeholder here forces
# a deployer to supply a real random value). Encode/decode raises TokenError
# at first use when this is empty, so the app still boots for read-only ops.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=
JWT_ACCESS_TOKEN_MINUTES=720          # 12 h — bump down for sensitive deployments

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. Replaces the previous
# wildcard. Streamlit dev server defaults to :8501.
FRONTEND_ORIGIN=http://localhost:8501
