# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: anthropic | openai | ollama
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Ollama (used when LLM_PROVIDER=ollama)
# Ollama runs on your machine; Docker reaches it via host.docker.internal
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# OLLAMA_API_KEY=ollama   ← Ollama doesn't need a real key but the field is required

# ── Database ──────────────────────────────────────────────────────────────────
# These are set automatically by docker-compose. Only override if running locally.
# DATABASE_URL=postgresql+psycopg://factory:factory@localhost:5432/factory
# DATABASE_URL_RO=postgresql+psycopg://factory_ro:factory_ro@localhost:5432/factory

# ── Embeddings ────────────────────────────────────────────────────────────────
# Set automatically by docker-compose. Only override if running locally.
# EMBEDDINGS_URL=http://localhost:8001
